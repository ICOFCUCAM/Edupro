# ─── Frontend (Vite) ───────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# All VITE_ variables are embedded in the browser bundle at build time.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase Edge Functions ────────────────────────────────────────────────────
# Set these as Supabase project secrets (supabase secrets set KEY=value)
# Do NOT prefix with VITE_ — these never reach the browser.

GATEWAY_API_KEY=your-ai-gateway-api-key-here
